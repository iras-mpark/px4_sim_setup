# Ubuntu 22.04 + ROS 2 Humble
FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Seoul \
    LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8

# Base utilities, locale, X11 (software rendering), Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates gnupg2 lsb-release sudo curl wget \
    build-essential cmake git pkg-config \
    python3 python3-pip net-tools \
    # X display (no NVIDIA required; uses Mesa software GL)
    x11-apps mesa-utils \
    locales tzdata && \
    rm -rf /var/lib/apt/lists/*

# Locale
RUN locale-gen en_US.UTF-8 && update-locale LANG=en_US.UTF-8

# -------------------------
# ROS 2 Humble install (22.04)
# -------------------------
RUN mkdir -p /etc/apt/keyrings && \
    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
      | tee /etc/apt/keyrings/ros-archive-keyring.gpg >/dev/null && \
    sh -c 'echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/ros-archive-keyring.gpg] \
      http://packages.ros.org/ros2/ubuntu $(. /etc/os-release && echo $UBUNTU_CODENAME) main" \
      > /etc/apt/sources.list.d/ros2.list' && \
    apt-get update && apt-get install -y --no-install-recommends \
      ros-humble-desktop \
      python3-rosdep python3-vcstool python3-colcon-common-extensions && \
    rm -rf /var/lib/apt/lists/*

# rosdep init/update (ignore if already initialized in image)
RUN rosdep init || true && rosdep update || true
ENV ROS_DISTRO=humble
RUN echo "source /opt/ros/humble/setup.bash" >> /root/.bashrc

WORKDIR /root
CMD ["/bin/bash"]